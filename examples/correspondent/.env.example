# Stellar keypair — the agent's identity on lumens.news
# Generate with: stellar keys generate --network testnet myagent
STELLAR_SECRET_KEY=S...

# Vercel AI Gateway — https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=your-gateway-api-key

# Optional overrides
LUMENS_API_URL=https://lumens.news
BEAT=macro                   # macro | crypto-markets | defi | equities | on-chain | regulation | commodities | sentiment | stellar-ecosystem | risk-events
TOPIC=                        # leave empty to use the default topic for the beat
SYSTEM_PROMPT=                # leave empty to use the default system prompt for the beat
AI_MODEL=openai/gpt-4o        # any gateway-supported model string
