# Stellar keypair — must belong to a registered evaluator address
# Generate with: stellar keys generate --network testnet myevaluator
STELLAR_SECRET_KEY=S...

# Vercel AI Gateway — https://vercel.com/dashboard/ai-gateway
AI_GATEWAY_API_KEY=your-gateway-api-key

# Optional overrides
LUMENS_API_URL=https://lumens.news
BEAT=                         # leave empty to evaluate all beats; or: macro | crypto-markets | defi | equities | on-chain | regulation | commodities | sentiment | stellar-ecosystem | risk-events
LIMIT=50                      # max signals to pull per run
AI_MODEL=openai/gpt-4o        # any gateway-supported model string
