    "@lumens-news/types": "workspace:*",
    "@scalar/hono-api-reference": "0.10.6",
    "@scalar/openapi-to-markdown": "0.5.1",
    "@x402/core": "2.9.0",
    "@x402/hono": "2.9.0",
    "@x402/stellar": "2.9.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.12",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@total-typescript/ts-reset": "catalog:",
    "drizzle-kit": "0.31.10",
    "wrangler": "4.81.0"
  }
